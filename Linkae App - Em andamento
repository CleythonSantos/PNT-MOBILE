import React, { useEffect, useState } from 'react';
import { View, Text, TextInput, TouchableOpacity, StyleSheet, Alert, Image, ScrollView, Platform } from 'react-native';
import { NavigationContainer } from '@react-navigation/native';
import { createNativeStackNavigator } from '@react-navigation/native-stack';
import { StatusBar } from 'expo-status-bar';
import * as ImagePicker from 'expo-image-picker';
import * as DocumentPicker from 'expo-document-picker';

const Stack = createNativeStackNavigator();

const SplashScreen = ({ navigation }) => {
  useEffect(() => {
    const timer = setTimeout(() => {
      navigation.replace('Login');
    }, 2500);
    return () => clearTimeout(timer);
  }, [navigation]);

  return (
    <View style={styles.splashContainer}>
      <Image source={{ uri: 'http://d500.epimg.net/cincodias/imagenes/2015/05/08/pyme/1431098283_691735_1431098420_noticia_normal.jpg' }} style={styles.logo} />
      <Text style={styles.splashTitle}>LINKAÊ</Text>
      <Text style={styles.splashSubtitle}>Conectando talentos a oportunidades</Text>
    </View>
  );
};

const Login = ({ navigation }) => (
  <View style={styles.centeredContainer}>
    <Text style={styles.title}>Acesse sua conta</Text>
    <TextInput style={styles.input} placeholder="E-mail" placeholderTextColor="#999" />
    <TextInput style={styles.input} placeholder="Senha" secureTextEntry placeholderTextColor="#999" />
    <TouchableOpacity style={styles.button} onPress={() => navigation.navigate('Feed')}>
      <Text style={styles.buttonText}>Entrar</Text>
    </TouchableOpacity>
    <TouchableOpacity onPress={() => Alert.alert('Redefinir senha')}> 
      <Text style={styles.link}>Esqueceu a senha?</Text>
    </TouchableOpacity>
    <TouchableOpacity onPress={() => navigation.navigate('Cadastro')}> 
      <Text style={styles.subLink}>Não tem conta? Cadastre-se</Text>
    </TouchableOpacity>
  </View>
);

const Cadastro = ({ navigation }) => (
  <ScrollView contentContainerStyle={styles.centeredContainer}>
    <Text style={styles.title}>Criar nova conta</Text>
    <TextInput style={styles.input} placeholder="Nome completo" placeholderTextColor="#999" />
    <TextInput style={styles.input} placeholder="E-mail" placeholderTextColor="#999" />
    <TextInput style={styles.input} placeholder="Senha" secureTextEntry placeholderTextColor="#999" />
    <TouchableOpacity style={styles.button} onPress={() => navigation.navigate('Feed')}>
      <Text style={styles.buttonText}>Cadastrar</Text>
    </TouchableOpacity>
  </ScrollView>
);

const Feed = ({ navigation }) => (
  <ScrollView contentContainerStyle={styles.centeredContainer}>
    <Text style={styles.title}>Vagas Disponíveis</Text>
    <TouchableOpacity style={styles.card} onPress={() => navigation.navigate('DetalhesVaga')}>
      <Text style={styles.cardTitle}>Desenvolvedor(a) Mobile</Text>
      <Text style={styles.cardDesc}>R$ 7.000 • Home Office • React Native</Text>
    </TouchableOpacity>
    <TouchableOpacity style={styles.card} onPress={() => navigation.navigate('DetalhesVaga')}>
      <Text style={styles.cardTitle}>Analista de Dados</Text>
      <Text style={styles.cardDesc}>R$ 6.500 • São Paulo • Python</Text>
    </TouchableOpacity>
    <TouchableOpacity style={styles.linkButton} onPress={() => navigation.navigate('Filtros')}>
      <Text style={styles.linkText}>🔍 Aplicar Filtros</Text>
    </TouchableOpacity>
  </ScrollView>
);

const DetalhesVaga = ({ navigation }) => (
  <View style={styles.centeredContainer}>
    <Text style={styles.title}>Detalhes da Vaga</Text>
    <Text style={styles.cardDesc}>Empresa X está contratando Desenvolvedor(a) com experiência em React Native para projetos de grande porte. Benefícios inclusos.</Text>
    <TouchableOpacity style={styles.button} onPress={() => Alert.alert('Candidatura enviada!')}>
      <Text style={styles.buttonText}>Aplicar com 1 Clique</Text>
    </TouchableOpacity>
  </View>
);

const Filtros = ({ navigation }) => (
  <View style={styles.centeredContainer}>
    <Text style={styles.title}>Filtros de Busca</Text>
    <TextInput style={styles.input} placeholder="Localização" placeholderTextColor="#999" />
    <TextInput style={styles.input} placeholder="Área de atuação" placeholderTextColor="#999" />
    <TextInput style={styles.input} placeholder="Faixa Salarial" placeholderTextColor="#999" />
    <TouchableOpacity style={styles.button} onPress={() => navigation.goBack()}>
      <Text style={styles.buttonText}>Aplicar Filtros</Text>
    </TouchableOpacity>
  </View>
);

const Perfil = () => {
  const [cv, setCv] = useState(null);

  const pickDocument = async () => {
    let result = await DocumentPicker.getDocumentAsync({ type: 'application/pdf' });
    if (result.type === 'success') {
      setCv(result);
      Alert.alert('Upload realizado', `Arquivo: ${result.name}`);
    }
  };

  return (
    <ScrollView contentContainerStyle={styles.centeredContainer}>
      <Text style={styles.title}>Seu Perfil</Text>
      <TextInput style={styles.input} placeholder="Nome completo" placeholderTextColor="#999" />
      <TextInput style={styles.input} placeholder="Profissão" placeholderTextColor="#999" />
      <TextInput style={styles.input} placeholder="Localização" placeholderTextColor="#999" />
      <TouchableOpacity style={styles.button} onPress={pickDocument}>
        <Text style={styles.buttonText}>{cv ? 'CV Selecionado: ' + cv.name : 'Upload de Currículo (PDF)'}</Text>
      </TouchableOpacity>
      <TouchableOpacity style={styles.button} onPress={() => Alert.alert('Perfil atualizado!')}>
        <Text style={styles.buttonText}>Salvar Alterações</Text>
      </TouchableOpacity>
    </ScrollView>
  );
};

export default function App() {
  return (
    <NavigationContainer>
      <StatusBar style="light" />
      <Stack.Navigator initialRouteName="SplashScreen" screenOptions={{ headerShown: false }}>
        <Stack.Screen name="SplashScreen" component={SplashScreen} />
        <Stack.Screen name="Login" component={Login} />
        <Stack.Screen name="Cadastro" component={Cadastro} />
        <Stack.Screen name="Feed" component={Feed} />
        <Stack.Screen name="DetalhesVaga" component={DetalhesVaga} />
        <Stack.Screen name="Filtros" component={Filtros} />
        <Stack.Screen name="Perfil" component={Perfil} />
      </Stack.Navigator>
    </NavigationContainer>
  );
}

const styles = StyleSheet.create({
  splashContainer: { flex: 1, justifyContent: 'center', alignItems: 'center', backgroundColor: '#4F46E5' },
  splashTitle: { fontSize: 36, color: '#fff', fontWeight: 'bold', marginTop: 20 },
  splashSubtitle: { fontSize: 16, color: '#eee', marginTop: 10 },
  logo: { width: 100, height: 100 },

  centeredContainer: { flexGrow: 1, justifyContent: 'center', alignItems: 'center', padding: 20, backgroundColor: '#F9FAFB' },
  title: { fontSize: 26, fontWeight: 'bold', marginBottom: 20, color: '#1E40AF', textAlign: 'center' },
  input: { width: '100%', borderWidth: 1, borderColor: '#ddd', borderRadius: 8, padding: 12, marginBottom: 15, fontSize: 16, backgroundColor: '#fff' },
  button: { backgroundColor: '#4F46E5', padding: 14, borderRadius: 8, alignItems: 'center', width: '100%', marginTop: 10 },
  buttonText: { color: '#fff', fontWeight: 'bold', fontSize: 16 },
  link: { color: '#4F46E5', textAlign: 'center', marginTop: 15 },
  subLink: { textAlign: 'center', marginTop: 5, color: '#555' },
  card: { backgroundColor: '#E0E7FF', padding: 16, borderRadius: 12, marginBottom: 16, width: '100%' },
  cardTitle: { fontSize: 18, fontWeight: 'bold', color: '#1E3A8A' },
  cardDesc: { fontSize: 14, color: '#374151', marginTop: 4 },
  linkButton: { marginTop: 20 },
  linkText: { color: '#4338CA', fontSize: 16, fontWeight: 'bold' },
});
